<?xml version="1.0"?>
<robot name="jack_in_the_box">

<material name="yellow">
    <color rgba="1.0 1.0 0.0 1.0"/>
  </material>

  <!-- Bottom -->
  <link name="base_link">
    <visual>
      <geometry><box size="1 1 0.05"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- Front wall -->
  <link name="front_wall">
    <visual>
      <geometry><box size="0.05 1 1"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- Back wall -->
  <link name="back_wall">
    <visual>
      <geometry><box size="0.05 1 1"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- Left wall -->
  <link name="left_wall">
    <visual>
      <geometry><box size="1 0.05 1"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- Right wall -->
  <link name="right_wall">
    <visual>
      <geometry><box size="1 0.05 1"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- Hinged Top Lid -->
  <link name="top_link">
    <visual>
      <geometry><box size="1 1 0.05"/></geometry>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- Fixed base cylinder  -->
  <link name="cylinder_base">
    <visual>
      <geometry><cylinder radius="0.1" length="0.6"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- Rising cylinder  -->
  <link name="cylinder_rise">
    <visual>
      <geometry><cylinder radius="0.08" length="0.6"/></geometry>
      <origin xyz="0 0 0.3" rpy="0 0 0"/>
    </visual>
  </link>

  <link name="head">
    <visual>
      <geometry><sphere radius="0.15"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="yellow"/>
    </visual>
  </link>

  <!-- Static wall joints -->
  <joint name="base_to_front" type="fixed">
    <parent link="base_link"/>
    <child link="front_wall"/>
    <origin xyz="0.475 0 0.5" rpy="0 0 0"/>
  </joint>

  <joint name="base_to_back" type="fixed">
    <parent link="base_link"/>
    <child link="back_wall"/>
    <origin xyz="-0.475 0 0.5" rpy="0 0 0"/>
  </joint>

  <joint name="base_to_left" type="fixed">
    <parent link="base_link"/>
    <child link="left_wall"/>
    <origin xyz="0 0.475 0.5" rpy="0 0 0"/>
  </joint>

  <joint name="base_to_right" type="fixed">
    <parent link="base_link"/>
    <child link="right_wall"/>
    <origin xyz="0 -0.475 0.5" rpy="0 0 0"/>
  </joint>

  <!-- Hinged top joint -->
  <joint name="top_to_back" type="revolute">
    <axis xyz="0 -1 0"/>
    <parent link="back_wall"/>
    <child link="top_link"/>
    <limit effort="1000.0" lower="0" upper="1.57" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0 0 0.5"/>
  </joint>

  
  <joint name="base_to_cylinder_base" type="fixed">
    <parent link="base_link"/>
    <child link="cylinder_base"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- Rising cylinder -->
  <joint name="cylinder_slide" type="prismatic">
    <axis xyz="0 0 1"/>
    <parent link="cylinder_base"/>
    <child link="cylinder_rise"/>
    <limit effort="1000.0" lower="0" upper="0.8" velocity="0.5"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Fix sphere to the top of the rising cylinder -->
  <joint name="rise_to_head" type="fixed">
    <parent link="cylinder_rise"/>
    <child link="head"/>
    <origin xyz="0 0 0.75" rpy="0 0 0"/>
  </joint>

</robot>
