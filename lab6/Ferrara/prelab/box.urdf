<?xml version="1.0"?>
<robot name="box">
  <link name="base_link">
    <visual>
      <geometry>
        <box size="1 1 0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <link name="right_link">
    <visual>
      <geometry>
        <box size="1 1 0.05"/>
      </geometry>
      <origin xyz="0 0 0.5" rpy="1.5708 0 0"/>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="right_to_bottom" type="fixed">
    <parent link="base_link"/>
    <child link="right_link"/>
    <origin rpy="0 0 0" xyz="0 0.5 0"/>
  </joint>

  <link name="back_link">
    <visual>
      <geometry>
        <box size="1 1 0.05"/>
      </geometry>
      <origin xyz="0 0 0.5" rpy="1.5708 0 1.5708"/>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <joint name="back_to_bottom" type="fixed">
    <parent link="base_link"/>
    <child link="back_link"/>
    <origin rpy="0 0 0" xyz="-0.5 0 0"/>
  </joint>

  <link name="left_link">
    <visual>
      <geometry>
        <box size="1 1 0.05"/>
      </geometry>
      <origin xyz="0 0 0.5" rpy="1.5708 0 0"/>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="left_to_bottom" type="fixed">
    <parent link="base_link"/>
    <child link="left_link"/>
    <origin rpy="0 0 0" xyz="0 -0.5 0"/>
  </joint>

  <link name="front_link">
    <visual>
      <geometry>
        <box size="1 1 0.05"/>
      </geometry>
      <origin xyz="0 0 0.5" rpy="1.5708 0 1.5708"/>
      <material name="cyan">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
  </link>

  <joint name="front_to_bottom" type="fixed">
    <parent link="base_link"/>
    <child link="front_link"/>
    <origin rpy="0 0 0" xyz="0.5 0 0"/>
  </joint>

  <link name="top_link">
    <visual>
      <geometry>
        <box size="1 1 0.05"/>
      </geometry>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
      <material name="purple">
        <color rgba="0.5 0 0.5 1"/>
      </material>
    </visual>
  </link>
  
  <joint name="top_to_back" type="revolute">
    <axis xyz="0 -1 0"/>
    <parent link="back_link"/>
    <child link="top_link"/>
    <limit effort="1000.0" lower="0" upper="1.57" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0 0 1"/>
  </joint>

  <link name="spring_base_link">
    <visual>
      <geometry>
        <cylinder length="0.8" radius="0.1" />
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.4"/>
      <material name="lime">
        <color rgba="0.5 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="spring_base" type="fixed">
    <parent link="base_link"/>
    <child link="spring_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="spring_link">
    <visual>
      <geometry>
        <cylinder length="0.8" radius="0.07"/>
      </geometry>
      <origin rpy="0 0 0.4" xyz="0 0 0.4"/>
      <material name="orange">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="spring_joint" type="prismatic">
    <axis xyz="0 0 1"/>
    <parent link="spring_base_link"/>
    <child link="spring_link"/>
    <limit effort="1000.0" lower="0" upper="0.8" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="jack">
    <visual>
      <geometry>
        <sphere radius="0.08"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.08"/>
      <material name="dark_blue">
        <color rgba="0 0 0.5 1"/>
      </material>
    </visual>
  </link>

  <joint name="jack_attach" type="fixed">
    <parent link="spring_link"/>
    <child link="jack"/>
    <origin rpy="0 0 0" xyz="0 0 0.8"/>
  </joint>
</robot>
